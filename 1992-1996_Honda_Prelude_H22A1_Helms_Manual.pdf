							//+ '		<img style="aspect-ratio:  100/100; height: 30px;" src="/graphics/icons_svg/bitcoin.svg">'
							+ '		<img style="aspect-ratio: 1000/597; height: 30px;" src="/graphics/icons_svg/mastercard.svg">'
							+ '		<img style="aspect-ratio: 1000/324; height: 20px;" src="/graphics/icons_svg/visa-logo.svg">'
							+ '		<img style="aspect-ratio: 1000/598; height: 30px;" src="/graphics/icons_svg/maestro.svg">'
							+ '		<img style="aspect-ratio: 1277/911; height: 55px;" src="/graphics/icons_svg/mollie-logo-black-2023.svg">'
							//+ '		<img style="aspect-ratio: 1000/266; height: 25px;" src="/graphics/icons_svg/paypal.svg">'
							//+ '		<a target="_blank" href="https://www.gopay.com/"><img style="aspect-ratio: 1000/235; height: 25px;" src="/graphics/icons_svg/gopay.svg"></a>'
						+ '	</div>'
					+ '</form>'
				+ '</div>'
				+ '<div style="clear: both;"></div>'
				;

			document.onkeydown = function(evt)
			{
				evt=(evt)?evt:((event)?event:null);
				if(evt.keyCode == 27)
				{
					//alert(123);
					manDownDonateAmkPay.hide();
					return false;
				}
			}

			/* Prevent clicking outside the dialog */
			document.body.style.pointerEvents = 'none';
			/* Prevent scrolling */
			document.body.style.overflow = 'hidden';

			document.getElementById('sle_email').focus();
		},

		init: function(as_price, al_price_usd)
		{
			manDownDonateAmkPay.html_obj = document.getElementById('popup_manDownDonate');
			manDownDonateAmkPay.price = as_price;

			manDownDonateAmkPay.price_usd = al_price_usd

			manDownDonateAmkPay.ddt1 = atob(manDownDonateAmkPay.session1);
			manDownDonateAmkPay.ddt2 = atob(manDownDonateAmkPay.session2);
			window.lng_10735 = 'Contribution to web operation';
			window.lng_6237 = 'Amount';
			window.lng_10736 = 'After entering your email address you will be redirected to the payment gateway';
			window.lng_11360 = 'Payment via %1 payment gateway after entering email address';
			window.lng_5004 = 'Email';
			window.lng_5603 = 'Cancel';
			window.lng_5993 = 'OK';
			window.lng_8333 = 'Pay';
			window.lng_5259 = 'Bad email';
			window.lng_11361 = 'Opening payment gateway, please stand by ..';
		},

		checkLogin: function(url)
		{
			return file_get_contents(url);
		},

		hide: function()
		{
			/* Release the Esc key. */
			document.onkeydown = function(evt)
			{
			};

			manDownDonateAmkPay.html_obj.style.display = 'none';
			document.getElementById('thisPageBody').style.opacity = '1';

			/* Re-enable clicking outside the dialog */
			document.body.style.pointerEvents = 'auto';
			/* Re-enable scrolling */
			document.body.style.overflow = '';
		},

		gpc: function(as_email)
		{
			document.getElementById('div_mandon_status').innerHTML = '';
			document.getElementById('cb_ok_gopay').value = 'Please wait';
			var url = window.location.protocol + '//' + window.location.hostname + '/' + this.ddt1 + '?what=manual&id=154&src=man001&email=' + as_email;
			
			var result = this.checkLogin(url);
						if(result == 'ERR_NOT_LOGGED_IN') f_login_redirect();
			if(result == 'ERR_EMAIL_INVALID')
			{
				var url = window.location.protocol + '//' + window.location.hostname + '/aaa.php';
				file_get_contents(url);
				document.getElementById('cb_ok_gopay').value = window.lng_5993;
				document.getElementById('sle_email').focus();
				document.getElementById('div_mandon_status').className = 'error';
				document.getElementById('div_mandon_status').innerHTML = window.lng_5259;
				return false;
			}
			document.getElementById('amkpay_button').innerHTML = '<br>' + 'Please wait' + '<br><br>';
			document.getElementById('cb_cancel').style.display = 'none';

			/* Re-enable clicking outside the dialog */
			document.body.style.pointerEvents = 'auto';
			/* Re-enable scrolling */
			document.body.style.overflow = '';

			document.getElementById('div_mandon_status').className = 'ok';
			document.getElementById('div_mandon_status').innerHTML = window.lng_11361;
			document.getElementById('frmManDownDonate').style.display = 'none';

			//_gopay.checkout({gatewayUrl: result, inline: true});

			//var url = 'https://cs.autoclub.eu' + '/' + this.ddt2 + '?what=manual&id=154&src=man001&email=' + as_email;
			var url = window.location.protocol + '//' + window.location.hostname + '/' + this.ddt2 + '?what=manual&id=154&src=man001&email=' + as_email;
			window.location.href = url;

			return;
		},
	}

</script>

