			background-color: #DDDDDD;
			min-height: 30px;
			max-height: 30px;
			font-size: 16px;
			font-family: Verdana;
			margin-bottom: 10px;
			overflow: hidden;
		}

		div#board div#highlighter
		{
			border-radius: 3px;
			box-sizing: content-box;
			background-color: inherit;
			max-height: 15px;
			padding: 5px 5px 5px 15px;
			position: absolute;
			left:0;
			top:0;
			clip: rect(0px 0px auto 0px);
			width: calc(100% - 80px);
		}

		div#board div.msgbox
		{
			box-sizing: content-box;
			float: right;
			padding: 6px 15px 5px 15px;
		}

		div#board div.msgbox a
		{
			font-size: 14px;
			#color: RED;
			vertical-align: bottom;
		}

		@media screen and (max-width: 300px) {

			div#board
			{
				#display: none;
				width: 0px !important;
				min-height: 0px !important;
				max-height: 0px !important;
				border: 0px !important;
			}

		}

		@media screen and (max-width: 210px) {

			div#board div#highlighter
			{
				padding-left: 2px;
				padding-right: 2px;
			}

			div#board div.msgbox
			{
				padding-left: 2px;
				padding-right: 2px;
			}

		}

	</style>

