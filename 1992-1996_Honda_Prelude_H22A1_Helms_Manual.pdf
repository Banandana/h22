	<script type="text/javascript">

		var tickercontents=new Array()

							tickercontents[0]='<a class="show_user_box" data-user-id="17162" style="color: #016D9A; word-break: break-all; font-size: inherit; font-family: Verdana;" href="' + 'https://' + window.location.hostname + '/member_detail.php?id=17162">achimbu</a>: <span style="word-break: break-all;">I am looking for a repair manual 1977 Civic SB2</span>';
					tickercontents[1]='<a class="show_user_box" data-user-id="15401" style="color: #016D9A; word-break: break-all; font-size: inherit; font-family: Verdana;" href="' + 'https://' + window.location.hostname + '/member_detail.php?id=15401">shaka</a>: <span style="word-break: break-all;">looking for a repair manual for Honda CR-V 2009 (CTD-i)</span>';
					tickercontents[2]='<a class="show_user_box" data-user-id="3" style="color: #EE0005; word-break: break-all; font-size: inherit; font-family: Verdana;" href="' + 'https://' + window.location.hostname + '/member_detail.php?id=3">club</a>: <A style="word-break: break-all; font-size: inherit;" href="https://en.club-honda.eu/vip"><span style="word-break: break-all;">Get all the VIP benefits and support the club at the same time</span></A>';
					tickercontents[3]='<a class="show_user_box" data-user-id="14693" style="color: #016D9A; word-break: break-all; font-size: inherit; font-family: Verdana;" href="' + 'https://' + window.location.hostname + '/member_detail.php?id=14693">Paulusromkes</a>: <span style="word-break: break-all;">I am searching for a manuel for a Gyro X TD02 4 takt </span>';
					tickercontents[4]='<a class="show_user_box" data-user-id="12763" style="color: #016D9A; word-break: break-all; font-size: inherit; font-family: Verdana;" href="' + 'https://' + window.location.hostname + '/member_detail.php?id=12763">Wafu125</a>: <span style="word-break: break-all;">Is there a workshop manual for the 2001 NSR125 JC22 Foxeye? </span>';
					tickercontents[5]='<a class="show_user_box" data-user-id="3" style="color: #EE0005; word-break: break-all; font-size: inherit; font-family: Verdana;" href="' + 'https://' + window.location.hostname + '/member_detail.php?id=3">club</a>: <A style="word-break: break-all; font-size: inherit;" href="https://en.club-honda.eu/business_card_general.php"><span style="word-break: break-all;">Cut-outs for children</span></A>';
					tickercontents[6]='<a class="show_user_box" data-user-id="3" style="color: #EE0005; word-break: break-all; font-size: inherit; font-family: Verdana;" href="' + 'https://' + window.location.hostname + '/member_detail.php?id=3">club</a>: <span style="word-break: break-all;">Welcome to the Honda fans and owners social network</span>';
		

		

					tickercontents[7]='<a style="font-size: inherit; font-family: Verdana;" target="" href=""></a>';
		


		var tickdelay=4000 //delay btw messages [microseconds]
		var highlightspeed=50 //10 pixels at a time.

		////Do not edit pass this line////////////////

		var currentmessage=0
		var clipwidth=0

		function changetickercontent()
		{
			crosstick.style.clip="rect(0px 0px auto 0px)"
			crosstick.innerHTML=tickercontents[currentmessage]
			highlightmsg()
		}

		function highlightmsg()
		{
			var msgwidth=crosstick.offsetWidth
			// 2015-09-04 by Pavel: added "&& clipwidth < 650" to the condition to prevent hidind the "Board" link if message is too long
			if (clipwidth<msgwidth && clipwidth < 650)
			{
				clipwidth+=highlightspeed
				crosstick.style.clip="rect(0px "+clipwidth+"px auto 0px)"
				beginclip=setTimeout("highlightmsg()",20)
			}
			else
			{
				clipwidth=0
				clearTimeout(beginclip)
				if (currentmessage==tickercontents.length-1) currentmessage=0
				else currentmessage++
				setTimeout("changetickercontent()",tickdelay)
			}
		}

		function start_ticking()
		{
			crosstick=document.getElementById? document.getElementById("highlighter") : document.all.highlighter
			crosstickParent=crosstick.parentNode? crosstick.parentNode : crosstick.parentElement
			if (parseInt(crosstick.offsetHeight)>0)
				crosstickParent.style.height=crosstick.offsetHeight+'px'
			else
				setTimeout("crosstickParent.style.height=crosstick.offsetHeight+'px'",100) //delay for Mozilla's sake
			changetickercontent()
		}

		if (document.all || document.getElementById) start_ticking();

	</script>










